---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import type { ui } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  lang?: keyof typeof ui;
}

const { 
  lang = 'en',
  title = lang === 'es' 
    ? "escal-ai | Consultoría de Inteligencia Artificial y Agentes Autónomos" 
    : "escal-ai | Artificial Intelligence Consulting & Autonomous Agents", 
  description = lang === 'es' 
    ? "Acompañamos a tu empresa en la transformación digital mediante consultoría estratégica de Inteligencia Artificial y desarrollo de agentes inteligentes a medida."
    : "We guide your business through digital transformation with strategic AI consulting and custom autonomous intelligent agents."
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <!-- Theme Initializer to prevent visual flash of dark/light on load -->
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const initialTheme = savedTheme || (systemPrefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', initialTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
  </head>
  <body>
    <Header lang={lang} />
    <main id="main-content" class="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

<style>
  .main-content {
    flex: 1 0 auto;
    padding-top: 4.5rem; /* Matches Header height */
    display: flex;
    flex-direction: column;
  }
</style>
