---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import type { ui } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  lang?: keyof typeof ui;
}

const { 
  lang = 'en',
  title = lang === 'es' 
    ? "escal-ai | Consultoría de Inteligencia Artificial y Agentes Autónomos" 
    : "escal-ai | Artificial Intelligence Consulting & Autonomous Agents", 
  description = lang === 'es' 
    ? "Acompañamos a pequeñas y medianas empresas (PYMEs) en su transformación digital mediante consultoría estratégica de Inteligencia Artificial y desarrollo de agentes autónomos a medida."
    : "We guide businesses in the LATAM market through digital transformation with strategic AI consulting and custom autonomous intelligent agents."
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <!-- Theme Initializer to prevent visual flash of dark/light on load -->
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const initialTheme = savedTheme || (systemPrefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', initialTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Fonts Preconnect (Performance Optimization) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical and Multilingual SEO -->
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang="en" href={new URL('/', Astro.site)} />
    <link rel="alternate" hreflang="es" href={new URL('/es/', Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site || Astro.url)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/og-image.png', Astro.site || Astro.url)} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{lang === 'es' ? 'Saltar al contenido' : 'Skip to Content'}</a>
    <Header lang={lang} />
    <main id="main-content" class="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

<style>
  .main-content {
    flex: 1 0 auto;
    padding-top: 4.5rem; /* Matches Header height */
    display: flex;
    flex-direction: column;
  }
</style>
