---
import MainLayout from '../layouts/MainLayout.astro';
import { useTranslations } from '../i18n/utils';
import type { ui } from '../i18n/ui';
import Mascot from './Mascot.astro';

interface Props {
  lang: keyof typeof ui;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<MainLayout lang={lang}>
  <!-- Hero Section -->
  <section class="hero-section section">
    <div class="container hero-container">
      <div class="hero-content">
        <h1 class="hero-title">
          {t('hero.title.1')}<span class="text-gradient">{t('hero.title.highlight')}</span>{t('hero.title.2')}
        </h1>
        <p class="hero-subtitle">
          {t('hero.subtitle')}
        </p>
        <div class="hero-cta">
          <a href="#products" class="btn btn-primary">{t('hero.btn.services')}</a>
          <a href="#contact" class="btn btn-secondary">{t('hero.btn.contact')}</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="visual-blob">
          <div class="glow-orb border-glow"></div>
          <div class="glow-orb inner-glow"></div>
          <div class="mascot-hero-wrapper">
            <Mascot type="full" size="large" animated={true} />
          </div>
          <div class="visual-card glass">
            <span class="card-tag">{t('hero.card.tag')}</span>
            <div class="card-status-row">
              <span class="status-indicator"></span>
              <span class="status-text">{t('hero.card.status')}</span>
            </div>
            <div class="card-bar-loader">
              <div class="card-bar-progress"></div>
            </div>
            <p class="card-description">{t('hero.card.desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="products" class="products-section section">
    <div class="container">
      <h2 class="section-title">{t('products.title')}</h2>
      <p class="section-subtitle">
        {t('products.subtitle')}
      </p>
      
      <div class="products-container">
        <!-- Product 1: Mobile Web Builder & Deployer -->
        <div class="product-item glass">
          <div class="product-badge">{t('products.tag')}</div>
          <div class="product-info">
            <div class="product-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
                <line x1="12" y1="18" x2="12.01" y2="18"></line>
              </svg>
            </div>
            <h3 class="product-title">{t('products.p1.title')}</h3>
            <p class="product-desc">{t('products.p1.desc')}</p>
          </div>
          
          <!-- Interactive Web Simulator -->
          <div class="simulator-wrapper web-simulator" role="region" aria-label={lang === 'es' ? "Simulador interactivo de creación de web móvil" : "Interactive mobile web builder simulator"}>
            <div class="phone-mockup glass">
              <div class="phone-header">
                <span class="phone-notch"></span>
              </div>
              <div class="phone-content">
                <div class="terminal-header">
                  <span class="dot red"></span>
                  <span class="dot yellow"></span>
                  <span class="dot green"></span>
                  <span class="terminal-title">escal-ai-agent</span>
                </div>
                <div class="terminal-body font-mono">
                  <p class="text-emerald">$ escal-ai --init</p>
                  <p class="typing-1">Prompt: Pizzeria with neon red order button...</p>
                  <p class="typing-2 text-muted">Building index.html...</p>
                  <p class="typing-3 text-muted">Optimizing CSS layout...</p>
                  <p class="typing-4 text-amber">Deploying to Cloudflare...</p>
                  <p class="typing-5 text-emerald">✔ Success: slice.dev</p>
                </div>
              </div>
            </div>
            
            <div class="browser-mockup glass">
              <div class="browser-header">
                <span class="browser-dots">
                  <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                </span>
                <span class="browser-url">slice.dev</span>
              </div>
              <div class="browser-content">
                <div class="preview-site">
                  <header class="preview-nav">
                    <span class="preview-logo">🍕 SliceHouse</span>
                    <span class="preview-menu-btn"></span>
                  </header>
                  <div class="preview-hero">
                    <h4>Fresh Pizza</h4>
                    <p>Delivered Hot & Fast</p>
                    <button class="preview-order-btn">Order Now</button>
                  </div>
                  <div class="preview-cloudflare-badge">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
                    </svg>
                    <span>Secure Cloudflare Deploy</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Product 2: Autonomous AI Support Agent -->
        <div class="product-item glass">
          <div class="product-badge">{t('products.tag')}</div>
          <div class="product-info">
            <div class="product-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
            </div>
            <h3 class="product-title">{t('products.p2.title')}</h3>
            <p class="product-desc">{t('products.p2.desc')}</p>
          </div>
          
          <!-- Interactive Chatbot Simulator -->
          <div class="simulator-wrapper bot-simulator" role="region" aria-label={lang === 'es' ? "Simulador interactivo de operaciones del agente de chat" : "Interactive chat agent operations simulator"}>
            <!-- Kanban operations tracking -->
            <div class="kanban-mockup glass">
              <h4 class="kanban-title">Agent Operations</h4>
              <div class="kanban-columns">
                <div class="kanban-col">
                  <h5>Inbound</h5>
                  <div class="kanban-card">
                    <span class="kanban-badge bg-whatsapp">WhatsApp</span>
                    <p>"Check stock..."</p>
                  </div>
                </div>
                <div class="kanban-col">
                  <h5>RAG Sync</h5>
                  <div class="kanban-card">
                    <span class="kanban-badge bg-emerald">Google Sheets</span>
                    <div class="spreadsheet-sync">
                      <span class="sync-ping"></span>
                      <p>menu_v2.xlsx</p>
                    </div>
                  </div>
                </div>
                <div class="kanban-col">
                  <h5>Live Status</h5>
                  <div class="kanban-card status-escalated">
                    <span class="kanban-badge bg-amber">Escalated</span>
                    <p>Manager Alerted</p>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- WhatsApp Chat mockup -->
            <div class="chat-mockup glass">
              <div class="chat-header">
                <span class="chat-avatar bg-whatsapp">AI</span>
                <div class="chat-user-info">
                  <span class="chat-username">Escal Agent</span>
                  <span class="chat-user-status">Online</span>
                </div>
              </div>
              <div class="chat-body font-sans">
                <div class="msg msg-user">
                  <p>Do you have Margherita pizza in stock?</p>
                </div>
                <div class="msg msg-bot msg-typing-1">
                  <p class="bot-thinking">Analyzing database...</p>
                </div>
                <div class="msg msg-bot msg-response-1">
                  <p>Checking Google Spreadsheet... Yes! We have 5 left for $12. Would you like to order?</p>
                </div>
                <div class="msg msg-user msg-user-2">
                  <p>This is late! I demand a refund right now.</p>
                </div>
                <div class="msg msg-bot msg-response-2">
                  <p>⚠️ High frustration detected. Disconnecting AI and escalating to manager on Telegram...</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section (B2B & Consulting Focus) -->
  <section id="services" class="services-section section">
    <div class="container">
      <h2 class="section-title">{t('services.title')}</h2>
      <p class="section-subtitle">
        {t('services.subtitle')}
      </p>
      
      <div class="grid grid-3">
        <div class="service-card glass">
          <div class="service-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
            </svg>
          </div>
          <h3 class="service-title">{t('services.s1.title')}</h3>
          <p class="service-desc">{t('services.s1.desc')}</p>
        </div>
        
        <div class="service-card glass">
          <div class="service-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
              <line x1="12" y1="22.08" x2="12" y2="12"></line>
            </svg>
          </div>
          <h3 class="service-title">{t('services.s2.title')}</h3>
          <p class="service-desc">{t('services.s2.desc')}</p>
        </div>
        
        <div class="service-card glass">
          <div class="service-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="5" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="2" y1="10" x2="22" y2="10"></line>
              <line x1="6" y1="15" x2="10" y2="15"></line>
            </svg>
          </div>
          <h3 class="service-title">{t('services.s3.title')}</h3>
          <p class="service-desc">{t('services.s3.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section id="process" class="process-section section">
    <div class="container">
      <h2 class="section-title">{t('process.title')}</h2>
      <p class="section-subtitle">
        {t('process.subtitle')}
      </p>
      
      <div class="process-steps">
        <div class="process-step">
          <div class="step-num">01</div>
          <div class="step-content">
            <h3 class="step-title">{t('process.step1.title')}</h3>
            <p class="step-desc">{t('process.step1.desc')}</p>
          </div>
        </div>
        
        <div class="process-step">
          <div class="step-num">02</div>
          <div class="step-content">
            <h3 class="step-title">{t('process.step2.title')}</h3>
            <p class="step-desc">{t('process.step2.desc')}</p>
          </div>
        </div>
        
        <div class="process-step">
          <div class="step-num">03</div>
          <div class="step-content">
            <h3 class="step-title">{t('process.step3.title')}</h3>
            <p class="step-desc">{t('process.step3.desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section (Strictly Anonymous) -->
  <section id="about" class="about-section section">
    <div class="container about-container">
      <div class="about-card glass">
        <h2 class="about-title">{t('about.title.1')}<span class="text-gradient">{t('about.title.2')}</span></h2>
        <p class="about-text">
          {t('about.text.1')}
        </p>
        <p class="about-text">
          {t('about.text.2')}
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Section (Conceptual & Store Badges) -->
  <section id="pricing" class="pricing-section section">
    <div class="container">
      <h2 class="section-title">{t('pricing.title')}</h2>
      <p class="section-subtitle">
        {t('pricing.subtitle')}
      </p>

      <div class="grid grid-2 pricing-grid">
        <!-- Column 1: Base Subscription -->
        <div class="pricing-card glass">
          <div class="pricing-badge bg-emerald-glow">{t('pricing.base.title')}</div>
          <h3 class="pricing-card-title">{t('pricing.base.title')}</h3>
          <p class="pricing-card-desc">{t('pricing.base.desc')}</p>
          
          <ul class="pricing-features">
            <li>
              <span class="feat-dot"></span>
              <div>
                <strong>Websites:</strong> {t('pricing.base.web')}
              </div>
            </li>
            <li>
              <span class="feat-dot"></span>
              <div>
                <strong>AI Chatbots:</strong> {t('pricing.base.bot')}
              </div>
            </li>
          </ul>
          <div class="pricing-action">
            <a href="#contact" class="btn btn-secondary pricing-btn">{t('pricing.cta')}</a>
          </div>
        </div>

        <!-- Column 2: Rent-An-Agent Developer Subscription -->
        <div class="pricing-card glass border-amber-glow">
          <div class="pricing-badge bg-amber-glow">{t('pricing.agent.title')}</div>
          <h3 class="pricing-card-title">{t('pricing.agent.title')}</h3>
          <p class="pricing-card-desc">{t('pricing.agent.desc')}</p>
          
          <ul class="pricing-features">
            <li>
              <span class="feat-dot bg-amber"></span>
              <div>
                <strong>Web Developer Mode:</strong> {t('pricing.agent.web')}
              </div>
            </li>
            <li>
              <span class="feat-dot bg-amber"></span>
              <div>
                <strong>Workflow Customizer:</strong> {t('pricing.agent.bot')}
              </div>
            </li>
          </ul>
          <div class="pricing-action">
            <a href="#contact" class="btn btn-primary pricing-btn">{t('pricing.cta')}</a>
          </div>
        </div>
      </div>

      <!-- App Download Action Card -->
      <div class="app-download-card glass">
        <span class="download-badge">{t('pricing.trial.tag')}</span>
        <h4>{t('pricing.trial.tag')}</h4>
        <p>{t('pricing.trial.desc')}</p>
        
        <div class="store-badges">
          <a href="#contact" class="store-btn glass upcoming-store-btn" aria-label="Apple App Store Beta access">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M15.97 4.17c.66-.81 1.11-1.93.99-3.06-1 .04-2.22.67-2.94 1.5-.63.73-1.18 1.87-1.03 2.98 1.12.09 2.27-.56 2.98-1.42z"></path>
            </svg>
            <div class="store-text">
              <span class="store-sub">{t('pricing.download.appstore.sub')}</span>
              <span class="store-main">{t('pricing.download.appstore.main')}</span>
            </div>
          </a>
          <a href="#contact" class="store-btn glass upcoming-store-btn" aria-label="Google Play Beta access">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
              <path d="M5.25 3.25c-.25.25-.38.64-.38 1.12v15.25c0 .48.13.87.38 1.12l.06.06L13.9 12l-.06-.06L5.31 3.19l-.06.06zM17.84 9.07l-3.9 3.87.06.06 3.9 2.25c1.1.64 1.92.17 1.92-1.12v-3.94c0-1.29-.82-1.76-1.92-1.12zM13.9 11.94L5.31 20.53c.3.3.83.33 1.43 0l11.1-6.41-3.94-2.18zM6.74 3.47L13.9 12.06l3.94-2.18-11.1-6.41c-.6-.33-1.13-.3-1.43 0z"></path>
            </svg>
            <div class="store-text">
              <span class="store-sub">{t('pricing.download.playstore.sub')}</span>
              <span class="store-main">{t('pricing.download.playstore.main')}</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="contact-section section">
    <div class="container contact-container">
      <h2 class="section-title">{t('contact.title')}</h2>
      <p class="section-subtitle">
        {t('contact.subtitle')}
      </p>
      
      <div class="contact-card glass">
        <h3 class="contact-card-title">{t('contact.card.title')}</h3>
        <p class="contact-card-text">{t('contact.card.desc')}</p>
        <div class="contact-actions">
          <a href="mailto:info@escal-ai.com?subject=Inquiry%20escal-ai" class="btn btn-primary contact-mail-btn">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            {t('contact.card.btn')}
          </a>
          <button id="copy-email-btn" class="btn btn-secondary contact-copy-btn" data-copied-text={t('contact.card.copied')} aria-label="Copy email address to clipboard">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span>{t('contact.card.copy')}</span>
          </button>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Ambient Background Glows */
  .products-section {
    background-image: radial-gradient(circle at 85% 40%, rgba(16, 185, 129, 0.05) 0%, transparent 65%);
  }
  .services-section {
    background-image: radial-gradient(circle at 50% 0%, rgba(16, 185, 129, 0.02) 0%, transparent 50%);
  }
  .process-section {
    background-image: radial-gradient(circle at 15% 45%, rgba(217, 119, 6, 0.04) 0%, transparent 65%);
  }
  .pricing-section {
    background-image: radial-gradient(circle at 50% 50%, rgba(16, 185, 129, 0.04) 0%, transparent 65%);
  }
  .contact-section {
    background-image: radial-gradient(circle at 50% 100%, rgba(217, 119, 6, 0.05) 0%, transparent 65%);
  }

  /* Hero Section styles */
  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    padding-top: 2rem;
  }

  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: left;
  }

  .hero-title {
    font-size: 3rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }
  }

  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 600px;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .visual-blob {
    width: 320px;
    height: 320px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
  }

  .border-glow {
    width: min(280px, 90%);
    height: min(280px, 90%);
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    opacity: 0.15;
    animation: orb-spin 20s linear infinite;
  }

  .inner-glow {
    width: min(200px, 65%);
    height: min(200px, 65%);
    background: radial-gradient(circle, var(--color-secondary) 0%, transparent 70%);
    opacity: 0.25;
  }

  .mascot-hero-wrapper {
    position: absolute;
    z-index: 3;
    top: -20px;
  }

  .visual-card {
    position: absolute;
    bottom: -30px;
    right: -40px;
    z-index: 4;
    padding: 1.75rem;
    width: 240px;
    text-align: left;
    border-color: rgba(16, 185, 129, 0.15);
  }

  @media (max-width: 768px) {
    .visual-blob {
      width: min(280px, 85vw);
      height: min(280px, 85vw);
    }
    .visual-card {
      bottom: -60px;
      right: auto;
      left: 50%;
      transform: translateX(-50%);
      width: min(250px, 85vw);
      padding: 1.25rem;
    }
  }

  .card-tag {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 0.5rem;
  }

  .card-status-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .status-indicator {
    width: 8px;
    height: 8px;
    background-color: var(--color-primary);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--color-primary);
    animation: pulse 1.5s ease-in-out infinite alternate;
  }

  .status-text {
    font-size: 0.9rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  .card-bar-loader {
    width: 100%;
    height: 4px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .card-bar-progress {
    width: 65%;
    height: 100%;
    background: var(--grad-brand);
    border-radius: 2px;
    animation: bar-load 3s ease-in-out infinite alternate;
  }

  .card-description {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* Products Section - Detailed Layout & Simulators */
  .products-container {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-top: 2rem;
  }

