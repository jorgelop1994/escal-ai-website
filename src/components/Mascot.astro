---
interface Props {
  type?: 'head' | 'full';
  size?: 'small' | 'medium' | 'large';
  animated?: boolean;
  className?: string;
}

const {
  type = 'head',
  size = 'medium',
  animated = true,
  className = ''
} = Astro.props;

// Determine viewBox and size styles based on props
const viewBox = type === 'head' ? '30 5 180 140' : '30 5 180 290';
---

<div class={`mascot-container ${size} ${type} ${animated ? 'animated' : ''} ${className}`}>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox={viewBox} fill="none" class="mascot-svg">
    <defs>
      <!-- Gradients -->
      <linearGradient id="headGrad" x1="120" y1="45" x2="120" y2="140" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#2a2e3b" />
        <stop offset="100%" stop-color="#14161d" />
      </linearGradient>
      
      <linearGradient id="bodyGrad" x1="120" y1="154" x2="120" y2="264" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#242833" />
        <stop offset="100%" stop-color="#111319" />
      </linearGradient>
      
      <linearGradient id="emeraldGrad" x1="80" y1="15" x2="160" y2="15" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#34d399" />
        <stop offset="100%" stop-color="#10b981" />
      </linearGradient>
      
      <linearGradient id="glowGrad" x1="120" y1="280" x2="120" y2="290" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="rgba(16, 185, 129, 0.4)" />
        <stop offset="100%" stop-color="rgba(16, 185, 129, 0.0)" />
      </linearGradient>

      <!-- Glow Filters -->
      <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      
      <filter id="glowBlur" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="6" />
      </filter>
      
      <filter id="dropShadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="8" stdDeviation="6" flood-color="#000000" flood-opacity="0.5" />
      </filter>
    </defs>

    <!-- Group containing the whole mascot, which floats -->
    <g class="mascot-float-group">
      <!-- 1. THRUSTER GLOW (Only for Full Body) -->
      {type === 'full' && (
        <ellipse cx="120" cy="282" rx="40" ry="7" fill="url(#glowGrad)" filter="url(#glowBlur)" class="mascot-glow" />
      )}

      <!-- 2. HEAD ASSEMBLY -->
      <g class="mascot-head-group">
        <!-- Antennae -->
        <g class="mascot-antennae">
          <!-- Stem base -->
          <ellipse cx="120" cy="45" rx="14" ry="5" fill="#1b1d24" stroke="#1d222e" stroke-width="2" />
          <!-- Left Antenna -->
          <line x1="112" y1="43" x2="85" y2="18" stroke="#4b5263" stroke-width="4.5" stroke-linecap="round" />
          <circle cx="85" cy="18" r="8.5" fill="url(#emeraldGrad)" filter="url(#glow)" />
          <!-- Right Antenna -->
          <line x1="128" y1="43" x2="155" y2="18" stroke="#4b5263" stroke-width="4.5" stroke-linecap="round" />
          <circle cx="155" cy="18" r="8.5" fill="url(#emeraldGrad)" filter="url(#glow)" />
        </g>

        <!-- Ears / Headphone Cushions -->
        <rect x="36" y="70" width="18" height="45" rx="7" fill="#16181f" stroke="#10b981" stroke-width="2" />
        <rect x="186" y="70" width="18" height="45" rx="7" fill="#16181f" stroke="#10b981" stroke-width="2" />
        <rect x="52" y="80" width="4" height="25" fill="#2d323f" />
        <rect x="184" y="80" width="4" height="25" fill="#2d323f" />

        <!-- Head Outer Casing -->
        <rect x="54" y="45" width="132" height="95" rx="28" ry="28" fill="url(#headGrad)" stroke="#1d222e" stroke-width="3" filter="url(#dropShadow)" />

        <!-- Faceplate Inner Screen -->
        <rect x="64" y="55" width="112" height="75" rx="18" ry="18" fill="#08090c" stroke="#1d222e" stroke-width="1.5" />

        <!-- Eyes -->
        <g class="mascot-eyes">
          <ellipse cx="94" cy="92" rx="14" ry="14" fill="url(#emeraldGrad)" class="mascot-eye eye-left" filter="url(#glow)" />
          <ellipse cx="146" cy="92" rx="14" ry="14" fill="url(#emeraldGrad)" class="mascot-eye eye-right" filter="url(#glow)" />
          <!-- Highlights -->
          <circle cx="90" cy="88" r="3" fill="#ffffff" opacity="0.8" class="mascot-eye-highlight" />
          <circle cx="142" cy="88" r="3" fill="#ffffff" opacity="0.8" class="mascot-eye-highlight" />
        </g>
      </g>

      <!-- 3. NECK & BODY (Only for Full Body) -->
      {type === 'full' && (
        <g class="mascot-body-group">
          <!-- Neck -->
          <rect x="102" y="137" width="36" height="20" rx="3" fill="#16181f" stroke="#1d222e" stroke-width="2" />
          
          <!-- Arms -->
          <!-- Left Arm -->
          <rect x="50" y="175" width="15" height="10" rx="2" fill="#1b1d24" stroke="#1d222e" stroke-width="1.5" />
          <rect x="42" y="180" width="11" height="52" rx="5" fill="url(#headGrad)" stroke="#1d222e" stroke-width="2" />
          <circle cx="47.5" cy="236" r="7" fill="#16181f" stroke="#1d222e" stroke-width="1.5" />
          
          <!-- Right Arm -->
          <rect x="175" y="175" width="15" height="10" rx="2" fill="#1b1d24" stroke="#1d222e" stroke-width="1.5" />
          <rect x="187" y="180" width="11" height="52" rx="5" fill="url(#headGrad)" stroke="#1d222e" stroke-width="2" />
          <circle cx="192.5" cy="236" r="7" fill="#16181f" stroke="#1d222e" stroke-width="1.5" />

          <!-- Torso Casing -->
          <rect x="66" y="152" width="108" height="110" rx="32" ry="32" fill="url(#bodyGrad)" stroke="#1d222e" stroke-width="3" filter="url(#dropShadow)" />

          <!-- Chest Screen -->
          <rect x="78" y="170" width="84" height="74" rx="14" ry="14" fill="#08090b" stroke="#1d222e" stroke-width="2" />

          <!-- Ascending Bar Chart (Live pulse / Escalation logo) -->
          <g class="mascot-chest-bars">
            <rect class="mascot-bar bar-1" x="90" y="222" width="6.5" height="10" rx="1.5" fill="url(#emeraldGrad)" filter="url(#glow)" />
            <rect class="mascot-bar bar-2" x="101" y="214" width="6.5" height="18" rx="1.5" fill="url(#emeraldGrad)" filter="url(#glow)" />
            <rect class="mascot-bar bar-3" x="112" y="206" width="6.5" height="26" rx="1.5" fill="url(#emeraldGrad)" filter="url(#glow)" />
            <rect class="mascot-bar bar-4" x="123" y="196" width="6.5" height="36" rx="1.5" fill="url(#emeraldGrad)" filter="url(#glow)" />
            <rect class="mascot-bar bar-5" x="134" y="184" width="6.5" height="48" rx="1.5" fill="url(#emeraldGrad)" filter="url(#glow)" />
          </g>
        </g>
      )}
    </g>
  </svg>
</div>

<style>
  .mascot-container {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    user-select: none;
  }

  /* Responsive Size Classes */
  .small {
    width: 32px;
    height: 32px;
  }
  .medium {
    width: 64px;
    height: 64px;
  }
  .large {
    width: 220px;
    height: 220px;
  }
  @media (max-width: 768px) {
    .large {
      width: 170px;
      height: 170px;
    }
  }

  .mascot-svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  /* --- ANIMATION KEYFRAMES --- */

  /* Floating Animation (Idle) */
  .animated.full .mascot-float-group {
    animation: floatFull 4s ease-in-out infinite;
  }
  .animated.head .mascot-float-group {
    animation: floatHead 3s ease-in-out infinite;
  }

  @keyframes floatFull {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
    100% { transform: translateY(0px); }
  }

  @keyframes floatHead {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-3px); }
    100% { transform: translateY(0px); }
  }

  /* Eye Blinking */
  .animated .mascot-eye {
    transform-box: fill-box;
    transform-origin: center;
    animation: blink 5s ease-in-out infinite;
  }
  .animated .mascot-eye-highlight {
    transform-box: fill-box;
    transform-origin: 90px 88px; /* Approximate center offset */
    animation: blinkHighlight 5s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 92%, 100% { transform: scaleY(1); }
    96% { transform: scaleY(0.08); }
  }
  @keyframes blinkHighlight {
    0%, 92%, 100% { opacity: 0.8; transform: scaleY(1); }
    96% { opacity: 0; transform: scaleY(0); }
  }

  /* Thruster Glow Pulsing */
  .animated .mascot-glow {
    transform-box: fill-box;
    transform-origin: center;
    animation: glowPulse 2s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.7; transform: scale(0.95); }
    50% { opacity: 1; transform: scale(1.05); }
  }

  /* Chest bar-chart sequential pulse (Live Processing) */
  .animated .mascot-bar {
    opacity: 0.3;
    animation: barPulse 2.5s ease-in-out infinite;
  }
  .animated .bar-1 { animation-delay: 0.1s; }
  .animated .bar-2 { animation-delay: 0.3s; }
  .animated .bar-3 { animation-delay: 0.5s; }
  .animated .bar-4 { animation-delay: 0.7s; }
  .animated .bar-5 { animation-delay: 0.9s; }

  @keyframes barPulse {
    0%, 30%, 100% { opacity: 0.35; filter: drop-shadow(0 0 0px rgba(16, 185, 129, 0)); }
    15% { opacity: 1; filter: drop-shadow(0 0 4px rgba(16, 185, 129, 0.8)); }
  }
</style>
